# Provedor de e-mail: "smtp" ou "mailgun"
EMAIL_PROVIDER=mailgun

# Remetente e destinatário (usado por ambos os provedores)
EMAIL_FROM_NAME=Thor Personal
EMAIL_FROM_EMAIL=thorpersonaloficial@gmail.com
EMAIL_CONTACT_RECIPIENT=thorpersonaloficial@gmail.com

# --- SMTP (quando EMAIL_PROVIDER=smtp) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-app-password

# --- Mailgun (quando EMAIL_PROVIDER=mailgun) ---
# MAILGUN_API_KEY=...
# MAILGUN_DOMAIN=mg.exemplo.com
# MAILGUN_EU=true
